generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Faculty {
  id              String       @id @default(cuid())
  name            String       @unique
  shortName       String       @unique
  dean            String
  establishedYear Int
  description     String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  departments     Department[]
}

model Department {
  id              String         @id @default(cuid())
  name            String
  head            String
  establishedYear Int
  totalStudents   Int            @default(0)
  description     String?
  facultyId       String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  faculty         Faculty        @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  programs        Program[]
  researchAreas   ResearchArea[]
  staff           Staff[]

  @@unique([name, facultyId])
}

model Program {
  id           String     @id @default(cuid())
  name         String
  departmentId String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([name, departmentId])
}

model ResearchArea {
  id           String     @id @default(cuid())
  name         String
  departmentId String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([name, departmentId])
}

model Staff {
  id                   String             @id @default(cuid())
  name                 String
  email                String             @unique
  designation          String
  departmentId         String
  status               StaffStatus        @default(APPROVED)
  studentsSupervised   Int                @default(0)
  studentsSupervisedDetails Json?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  bio                  String?
  experienceYears      String?
  profileImage         String?
  qualifications       String?
  specialization       String?
  administrativeDuties      String?
  teachingLoad              Json?
  profileVerificationStatus VerificationStatus @default(PENDING)
  profileRejectionReason    String?
  courses              Course[]
  projects             Project[]
  publications         Publication[]
  equipmentRequests    EquipmentRequest[]
  department           Department         @relation(fields: [departmentId], references: [id], onDelete: Cascade)
}

model Publication {
  id              String          @id @default(cuid())
  title           String
  authors         String          // Comma-separated list or JSON array
  year            Int
  publicationType PublicationType @default(JOURNAL_ARTICLE)
  journal         String?         // Journal or Conference name
  volume          String?
  issue           String?
  pages           String?         // e.g., "123-145"
  publisher       String?
  doi             String?         // Digital Object Identifier
  isbn            String?         // For books
  issn            String?         // For journals
  abstract        String?         @db.Text
  keywords        String?         // Comma-separated keywords
  url             String?         // Link to publication
  pdfUrl          String?         // Direct link to PDF
  impactFactor    String?         // Journal impact factor
  indexedIn       String?         // e.g., "Scopus, Web of Science, PubMed"
  citationCount        Int                @default(0)
  verified             Boolean            @default(false)
  verificationStatus   VerificationStatus @default(PENDING)
  rejectionReason      String?
  imageUrl             String?
  staffId              String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  staff           Staff           @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([year])
  @@index([publicationType])
  @@index([verified])
}

model Project {
  id             String        @id @default(cuid())
  title          String
  description    String?       @db.Text
  objectives     String?       @db.Text
  methodology    String?       @db.Text
  outcomes       String?       @db.Text
  studentCount   Int           @default(0)

  // ── Classification (Faculty fills) ──────────────────────────────────────
  projectKind    ProjectKind   @default(RESEARCH)
  scope          ProjectScope  @default(NATIONAL)
  thematicArea   String?
  projectCategory String?      // e.g. "RESEARCH", "DEVELOPMENT", "INNOVATION"
  projectType    String?       // e.g. "INDIVIDUAL", "GROUP", "JOINT"
  funderType     String?       // e.g. "HEC", "MNSUAM", "INDUSTRY", "INTERNATIONAL"
  funderLocation String?       // "NATIONAL" | "INTERNATIONAL"
  funderCountry  String?
  fundingCallTitle String?
  dateOfCirculation DateTime?
  submissionDeadline DateTime?
  shiftedToMnsuam DateTime?

  // ── Industry project specifics (Faculty fills) ───────────────────────────
  projectFileNo  String?
  financialYear  String?       // e.g. "2024-25"
  awardDate      DateTime?
  sponsoringAgency String?
  sponsorCountry String?
  sponsorAddress String?       @db.Text
  counterpartName String?
  counterpartCountry String?
  counterpartAddress String?   @db.Text

  // ── Funding (ORIC/Admin manages) ─────────────────────────────────────────
  fundingAmount  String?
  budgetAmount   Decimal?      @db.Decimal(14, 2)
  currency       String?       @default("PKR")
  fundingAgency  String?
  collaborators  String?
  oricOverheadAmount Decimal?  @db.Decimal(14, 2)
  overheadStatus String?       @default("Approved")

  // ── Post-Award (ORIC fills after approval) ───────────────────────────────
  awardLetterDate    DateTime?
  fundingAgencyRefNo String?
  awardLetterUrl     String?
  specialConditions  String?   @db.Text

  // ── Work plan ────────────────────────────────────────────────────────────
  targetBeneficiaries String?  @db.Text
  reportingFrequency  String?  @default("Annual")

  // ── Deliverables & status (ORIC tracks) ──────────────────────────────────
  deliverables   String?       @db.Text
  monitoringPlan String?       @db.Text
  reportsStatus  String?       @default("No Report Due")
  fileStatus     String?       @default("File Received")
  remarks        String?       @db.Text

  // ── Post-completion (ORIC fills) ──────────────────────────────────────────
  innovationType          String?
  patentable              Boolean?
  patentFiledDate         DateTime?
  innovativeStatus        String?
  commercializationStatus String?

  projectUrl          String?
  imageUrl            String?
  verificationStatus  VerificationStatus @default(PENDING)
  rejectionReason     String?
  status              ProjectStatus @default(SUBMITTED)
  startDate      DateTime?
  endDate        DateTime?
  staffId        String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  staff          Staff         @relation(fields: [staffId], references: [id], onDelete: Cascade)
  installments   Installment[]
  coPIs          ProjectCoPI[]
  teamMembers    ProjectTeamMember[]
  reports        ProjectReport[]

  @@index([status])
  @@index([projectKind])
  @@index([verificationStatus])
}

model ProjectCoPI {
  id           String   @id @default(cuid())
  projectId    String
  name         String
  designation  String?
  organization String?
  contact      String?
  email        String?
  type         String   @default("Internal")
  createdAt    DateTime @default(now())
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProjectTeamMember {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  designation String?
  department  String?
  role        String?
  createdAt   DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProjectReport {
  id             String    @id @default(cuid())
  projectId      String
  reportType     String    @default("Progress")
  dueDate        DateTime?
  submissionDate DateTime?
  status         String    @default("Due")
  fileUrl        String?
  createdAt      DateTime  @default(now())
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Installment {
  id            String            @id @default(cuid())
  projectId     String
  installmentNo Int               // 1, 2, 3 ...
  amount        Decimal           @db.Decimal(14, 2)
  dueDate       DateTime?
  releaseDate   DateTime?
  status        InstallmentStatus @default(PENDING)
  note          String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  project       Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, installmentNo])
  @@index([projectId])
  @@index([status])
}

model Course {
  id                 String             @id @default(cuid())
  name               String
  credits            Int
  students           Int                @default(0)
  verificationStatus VerificationStatus @default(PENDING)
  rejectionReason    String?
  staffId            String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([name, staffId])
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String
  role      UserRole  @default(FACULTY)
  staffId   String?   @unique
  isActive  Boolean   @default(true)
  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  performedBy String
  targetType  String
  targetId    String
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([performedBy, createdAt])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model Lab {
  id          String      @id @default(cuid())
  name        String      @unique
  floor       String
  labInCharge String
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  equipment   Equipment[]
}

model Equipment {
  id        String             @id @default(cuid())
  srNo      Int?
  name      String
  model     String?
  quantity  Int                @default(1)
  notes     String?
  labId     String
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  lab       Lab                @relation(fields: [labId], references: [id], onDelete: Cascade)
  requests  EquipmentRequest[]
}

model EquipmentRequest {
  id            String        @id @default(cuid())
  equipmentId   String
  staffId       String
  purpose       String
  studentInfo   String?       // Who will use the equipment (student names/IDs/details)
  requestedFrom DateTime
  requestedTo   DateTime
  status        RequestStatus @default(PENDING)
  adminNotes    String?
  approvedAt    DateTime?
  borrowedAt    DateTime?
  returnedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  equipment     Equipment     @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  staff         Staff         @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([staffId])
  @@index([equipmentId])
}

enum StaffStatus {
  APPROVED
  PENDING
  REJECTED
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  RETURNED
}

enum ProjectStatus {
  SUBMITTED
  ONGOING
  COMPLETED
  PENDING
}

enum ProjectKind {
  RESEARCH
  INDUSTRY
}

enum ProjectScope {
  NATIONAL
  INTERNATIONAL
}

enum InstallmentStatus {
  PENDING
  RELEASED
}

enum UserRole {
  ADMIN
  FACULTY
  STUDENT
}

enum PublicationType {
  JOURNAL_ARTICLE
  CONFERENCE_PAPER
  BOOK
  BOOK_CHAPTER
  THESIS
  PATENT
  TECHNICAL_REPORT
  WORKING_PAPER
  PREPRINT
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  link      String?
  metadata  Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([isRead])
  @@index([createdAt])
}
